{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@epos/domain": ["packages/domain/src"],
      "@epos/ports": ["packages/ports/src"],
      "@epos/application": ["packages/application/src"],
      "@epos/api": ["packages/api/src"],
      "@epos/infrastructure-postgres": ["packages/infrastructure-postgres/src"],
      "@epos/infrastructure-models": ["packages/infrastructure-models/src"],
      "@epos/infrastructure-mcp": ["packages/infrastructure-mcp/src"],
      "@epos/infrastructure-runtime": ["packages/infrastructure-runtime/src"],
      "@epos/observability": ["packages/observability/src"],
      "@epos/testing": ["packages/testing/src"]
    }
  }
}
