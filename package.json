{
  "name": "epistemic-os",
  "version": "0.1.0-rc.1",
  "description": "Epistemic Operating System v1.0 — a platform for traceable reasoning and human-in-the-loop AI workflows.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm --filter @epios/domain test:coverage",
    "test:domain": "pnpm --filter @epios/domain test",
    "test:contracts": "pnpm --filter @epios/api test",
    "test:postgres": "pnpm --filter @epios/infrastructure-postgres test",
    "test:async": "echo 'Async tests not yet implemented' && exit 0",
    "test:e2e": "npx playwright test",
    "test:security": "echo 'Security tests not yet implemented' && exit 0",
    "test:trace": "pnpm --filter @epios/observability test",
    "qa:adr-review": "pnpm verify && pnpm test:e2e && pnpm test:trace",
    "demo:adr-review": "pnpm --filter demo-shell dev",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @epios/infrastructure-postgres migrate",
    "db:seed": "pnpm --filter @epios/infrastructure-postgres seed",
    "db:reset": "pnpm db:down && docker compose up -d postgres && pnpm db:migrate && pnpm db:seed",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm depcruise",
    "ci:release": "pnpm verify && pnpm build && pnpm depcruise",
    "depcruise": "depcruise packages apps",
    "refresh-map": "node dev_studio/refresh.cjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.7.0",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9.2.0",
    "globals": "^17.6.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.6.0"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
